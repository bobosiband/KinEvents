PORT=3001
NODE_ENV=development
JWT_SECRET=

# Email — option A: Gmail with App Password (recommended)
GMAIL_USER=youremail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Email — option B: Resend
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=notifications@yourdomain.com

# Shared email config
EMAIL_FROM_NAME=KinEvents

# Other
SENDGRID_API_KEY=unused-can-be-any-value
APP_URL=http://localhost:3001
MONGODB_DB_NAME=kinevents


