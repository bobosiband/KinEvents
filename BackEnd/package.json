{
  "name": "kinevents-backend",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "start": "node dist/src/local/server.js",
    "dev": "ts-node src/local/server.ts",
    "build": "tsc",
    "sam:build": "sam build",
    "local": "sam local start-api --port 3000",
    "deploy": "bash -lc 'set -a; source ./.env; set +a; npm run deploy:run'",
    "deploy:run": "npm run build && npm run deploy:clean-pkg && npm run deploy:package && npm run deploy:upload",
    "deploy:clean-pkg": "rm -rf .lambda-pkg && mkdir .lambda-pkg && cp -r dist data .lambda-pkg/ && cp package.json package-lock.json .lambda-pkg/ && cd .lambda-pkg && npm ci --omit=dev",
    "deploy:package": "cd .lambda-pkg && zip -r ../.lambda-pkg.zip . -q && cd ..",
    "deploy:upload": "aws lambda update-function-code --function-name kinevents-backend-KinEventsFunction-VYEGgUmx4oGJ --zip-file fileb://.lambda-pkg.zip --publish --region us-east-1",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --runInBand",
    "ci": "npm run build && npm test -- --runInBand"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.2.0",
    "serverless-http": "^4.0.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@vercel/node": "^4.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.15.2",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "openapi-types": "^12.1.3",
    "serverless": "^4.35.1",
    "serverless-offline": "^14.5.0",
    "supertest": "^7.1.1",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "swagger-jsdoc": "^6.2.8"
  }
}
