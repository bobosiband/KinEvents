{
  "name": "kinevents-backend",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "start": "node dist/src/local/server.js",
    "dev": "ts-node src/local/server.ts",
    "build": "tsc",
    "sam:build": "sam build",
    "local": "sam local start-api --port 3001",
    "deploy": "npm run build && sam deploy --guided",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --runInBand",
    "ci": "npm run build && npm test -- --runInBand"
  },
  "dependencies": {
    "@vercel/node": "^4.0.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "lowdb": "^3.0.0",
    "serverless-http": "^4.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.15.2",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "openapi-types": "^12.1.3",
    "serverless": "^4.35.1",
    "serverless-offline": "^14.5.0",
    "supertest": "^7.1.1",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
